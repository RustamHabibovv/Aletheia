# ============================================
# Aletheia — Production environment (frontend)
# Copy this to /home/aletheia/app/frontend/.env.local on the VPS and fill in.
# NEXT_PUBLIC_* values are baked into the build — set BEFORE `npm run build`.
# ============================================

# Must match NEXTAUTH_SECRET in backend .env exactly (used to sign JWTs both
# verify).
NEXTAUTH_SECRET=REPLACE_WITH_SAME_VALUE_AS_BACKEND

# Public site URL — NextAuth uses this to generate OAuth callback URLs.
NEXTAUTH_URL=https://aletheiai.ai

# Required when running behind a reverse proxy (Nginx). NextAuth v5 refuses to
# trust the host header without this.
AUTH_TRUST_HOST=true

# Server-side calls from Next.js to FastAPI (same VPS, localhost is faster).
BACKEND_URL=http://localhost:8000

# Client-side (browser) calls — Nginx routes /api/v1/* to FastAPI on the same host.
NEXT_PUBLIC_API_URL=https://aletheiai.ai

# Google OAuth — same values as backend.
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
