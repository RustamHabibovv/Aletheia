# ============================================
# Aletheia Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- App ---
DEBUG=true
AUTO_CREATE_TABLES=true  # Set to true for local dev/tests (skips needing Alembic migrations)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
# SQLite (default for local dev — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./aletheia_dev.db
# Postgres (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aletheia

# --- Auth (Auth.js / NextAuth) ---
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- OpenRouter (used by agents) ---
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Tavily Search ---
TAVILY_API_KEY=tvly-your-tavily-api-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# --- Twilio WhatsApp (Sprint 5) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=
