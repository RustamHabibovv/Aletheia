# ============================================
# Aletheia — Production environment (backend)
# Copy this to /home/aletheia/app/.env on the VPS and fill in real values.
# chmod 600 .env after writing.
# ============================================

# --- App ---
DEBUG=false
AUTO_CREATE_TABLES=false
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["https://aletheiai.ai"]

# --- Database ---
# In Docker, docker-compose.prod.yml builds DATABASE_URL from POSTGRES_PASSWORD
# and uses the "postgres" container hostname. Set the password below; the URL
# is generated for you.
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# --- Auth (Auth.js / NextAuth) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
NEXTAUTH_URL=https://aletheiai.ai

# --- Google OAuth ---
# Same Google project, but add https://aletheiai.ai/api/auth/callback/google
# to Authorized redirect URIs in Google Cloud Console.
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_KEY
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Tavily Search ---
TAVILY_API_KEY=REPLACE_WITH_TAVILY_KEY

# --- Sapling (AI text detection) ---
SAPLING_API_KEY=REPLACE_WITH_SAPLING_KEY

# --- Stripe (LIVE MODE) ---
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_YEARLY=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_YEARLY=price_REPLACE_ME
STRIPE_SUCCESS_URL=https://aletheiai.ai/?subscribed=1
STRIPE_CANCEL_URL=https://aletheiai.ai/
